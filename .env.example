# mock is the safe default. live starts Playwright and navigates to configured origins.
SERVICE_MODE=mock
HOST=127.0.0.1
PORT=8787

# Existing Chrome profile / Playwright persistent context userDataDir.
USER_DATA_DIR=/Users/pengcheng/chrome-agent-auth-profile

# Live browser settings.
BROWSER_HEADLESS=true
PLAYWRIGHT_CHANNEL=chrome
REQUEST_TIMEOUT_MS=15000
MAX_LIVE_BODY_BYTES=65536

# Required only when SERVICE_MODE=live. Keep these as fixed origins, not request inputs.
RCP_ORIGIN=https://rcp.example.invalid
WEAPON_ORIGIN=https://weapon.example.invalid
LOGIN_LOGS_ORIGIN=https://login-logs.example.invalid
TRACK_ANALYSIS_ORIGIN=https://track-analysis.example.invalid

# Optional live prewarm paths. They must remain same-origin relative paths.
RCP_PREWARM_PATH=/
WEAPON_PREWARM_PATH=/
LOGIN_LOGS_PREWARM_PATH=/
TRACK_ANALYSIS_PREWARM_PATH=/
